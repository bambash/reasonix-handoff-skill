#!/usr/bin/env bash
# rxbroker — deterministic, idempotent broker for DeepSeek-Reasonix sessions.
#
# Brokers code-generation / code-review / openspec work to `reasonix`, reusing a
# stable per-(repo,type,model,thread) session file so DeepSeek's prefix cache hits.
#
# Subcommands: key | ensure | run | run-task | list | capabilities | promote | stop
# (see `rxbroker help`)
set -euo pipefail

SELF_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=lib/common.sh
source "$SELF_DIR/lib/common.sh"

# ---- dependency check ------------------------------------------------------
for _bin in jq flock sha256sum; do
  command -v "$_bin" >/dev/null 2>&1 || rxb_die "missing required tool: $_bin"
done

rxb_need_reasonix() {
  command -v reasonix >/dev/null 2>&1 || rxb_die "missing required tool: reasonix"
}

usage() {
  cat <<'EOF'
rxbroker — broker DeepSeek-Reasonix sessions for cache-stable agent handoff.

Usage:
  rxbroker key     --type T --thread ID [--model M] [--repo DIR]
  rxbroker ensure  --type T --thread ID [--model M] [--repo DIR]
  rxbroker run     --type T --thread ID [--model M] [--repo DIR]
                   [--agent NAME] [--max-steps N] [--raw] (<task> | -)
  rxbroker run-task TASK.json [--raw]
  rxbroker list    [--type T] [--thread ID] [--repo DIR]
  rxbroker capabilities [--repo DIR]
  rxbroker promote --type T --thread ID [--model M] [--repo DIR] [--addr HOST:PORT]
  rxbroker stop    --type T --thread ID [--model M] [--repo DIR]

Common flags:
  --type      codegen | review | openspec   (forces a separate session lineage)
  --thread    stable logical id; SAME id reconnects (cache hit), NEW id forks
  --model     override the per-type model from config (changes the session key)
  --repo      project dir (default: $PWD; resolves to git toplevel if any)
  --agent     optional calling sub-agent id; echoed in JSON envelopes
  --max-steps reasonix tool-call round cap for `run` (0 = config default)
  --raw       `run`: stream reasonix output as text instead of a JSON envelope
  -           `run`: read the task prompt from stdin

run-task expects a JSON file with: type, thread, optional repo/model/agent/max_steps,
and either prompt or objective. The full task envelope is forwarded to reasonix.

All commands print JSON to stdout (except `run --raw`).
EOF
}

# ---- argument parsing ------------------------------------------------------
TYPE="" THREAD="" REPO="$PWD" ADDR="" MAXSTEPS="" RAW=0 AGENT=""
RXB_MODEL_OVERRIDE=""
POSITIONAL=()
parse_args() {
  while [ $# -gt 0 ]; do
    case "$1" in
      --type)      TYPE="${2:-}"; shift 2 ;;
      --thread)    THREAD="${2:-}"; shift 2 ;;
      --model)     RXB_MODEL_OVERRIDE="${2:-}"; shift 2 ;;
      --repo)      REPO="${2:-}"; shift 2 ;;
      --agent)     AGENT="${2:-}"; shift 2 ;;
      --addr)      ADDR="${2:-}"; shift 2 ;;
      --max-steps) MAXSTEPS="${2:-}"; shift 2 ;;
      --raw)       RAW=1; shift ;;
      -h|--help)   usage; exit 0 ;;
      --)          shift; while [ $# -gt 0 ]; do POSITIONAL+=("$1"); shift; done ;;
      -)           POSITIONAL+=("-"); shift ;;
      -*)          rxb_die "unknown flag: $1" ;;
      *)           POSITIONAL+=("$1"); shift ;;
    esac
  done
}

# Validate + derive the common (key, path, model) tuple for a session command.
resolve_session() {
  [ -n "$TYPE" ]   || rxb_die "--type is required"
  rxb_is_type "$TYPE" || rxb_die "invalid --type '$TYPE' (want: $RXB_TYPES)"
  [ -n "$THREAD" ] || rxb_die "--thread is required"
  rxb_init_paths "$REPO"
  MODEL=$(rxb_model_for "$TYPE")
  KEY=$(rxb_key "$RXB_REPO_ID" "$TYPE" "$MODEL" "$THREAD")
  SPATH_JSONL=$(rxb_session_path "$RXB_STATE" "$TYPE" "$KEY")
}

# Count sessions in the index for the soft concurrency advisory.
concurrency_json() {
  local active cap
  active=$(jq 'length' "$RXB_INDEX" 2>/dev/null || echo 0)
  cap=$(rxb_cfg_get limits concurrency_cap || echo 4)
  jq -nc --argjson a "$active" --argjson c "$cap" \
    '{active:$a, cap:$c, over: ($a > $c)}'
}

session_meta_json() { # status
  jq -nc \
    --arg key "$KEY" --arg path "$SPATH_JSONL" --arg type "$TYPE" \
    --arg thread "$THREAD" --arg model "$MODEL" --arg repo "$RXB_REPO_ID" \
    --arg agent "$AGENT" --arg status "${1:-}" \
    '{key:$key, path:$path, type:$type, thread:$thread, model:$model, repo:$repo}
     + (if $agent=="" then {} else {agent:$agent} end)
     + (if $status=="" then {} else {status:$status} end)'
}

# ---- subcommand: key -------------------------------------------------------
cmd_key() { resolve_session; session_meta_json; }

# ---- subcommand: ensure ----------------------------------------------------
# Idempotent: create the empty session file + index entry only if absent.
# reasonix `run -resume` requires the file to pre-exist, so we own it as empty.
cmd_ensure() {
  resolve_session
  rxb_index_init
  mkdir -p "$(dirname "$SPATH_JSONL")" "$(rxb_locks_dir "$RXB_STATE")"
  local status
  if [ -f "$SPATH_JSONL" ] && rxb_index_get "$KEY" >/dev/null; then
    status="reused"
  else
    [ -f "$SPATH_JSONL" ] || : > "$SPATH_JSONL"
    rxb_index_apply "$KEY" \
      ".[\$k] = ((.[\$k] // {}) + {type:\"$TYPE\", thread:\"$THREAD\", model:\"$MODEL\", path:\"$SPATH_JSONL\", turns:((.[\$k].turns)//0), created_at:((.[\$k].created_at)//$(rxb_now)), last_used:((.[\$k].last_used)//0)})"
    status="created"
  fi
  session_meta_json "$status"
}

# ---- subcommand: run -------------------------------------------------------
cmd_run() {
  rxb_need_reasonix
  resolve_session
  # task: from positional arg, or stdin when "-" (or no arg) is given.
  local task=""
  if [ "${#POSITIONAL[@]}" -gt 0 ] && [ "${POSITIONAL[0]}" != "-" ]; then
    task="${POSITIONAL[0]}"
  else
    task="$(cat)"
  fi
  [ -n "$task" ] || rxb_die "run: empty task (pass <task> or pipe via -)"

  local estatus
  estatus=$(cmd_ensure | jq -r '.status')   # guarantees file + index entry; idempotent

  local steps; steps="${MAXSTEPS:-$(rxb_cfg_get run max_steps || echo 0)}"
  local lock="$(rxb_locks_dir "$RXB_STATE")/$KEY.lock"
  local metrics out rc
  metrics=$(mktemp); out=$(mktemp)

  # Per-key lock serializes concurrent runs on the SAME session (protects the
  # append-only JSONL + prefix invariant). Different keys run in parallel.
  set +e
  (
    flock 8
    reasonix run -dir "$RXB_REPO_ID" -model "$MODEL" -resume "$SPATH_JSONL" \
      -max-steps "$steps" -metrics "$metrics" "$task" </dev/null
  ) 8>"$lock" >"$out" 2>&1
  rc=$?
  set -e

  rxb_index_apply "$KEY" \
    ".[\$k].turns = ((.[\$k].turns)//0) + 1 | .[\$k].last_used = $(rxb_now)"

  if [ "$RAW" -eq 1 ]; then
    cat "$out"
    rm -f "$metrics" "$out"
    return "$rc"
  fi

  local turns; turns=$(rxb_index_get "$KEY" | jq '.turns // 0')
  # Strip ANSI escapes from captured output for clean embedding.
  sed -r 's/\x1b\[[0-9;]*[A-Za-z]//g' "$out" > "$out.clean" || cp "$out" "$out.clean"
  jq -n \
    --argjson meta "$(session_meta_json "$estatus")" \
    --argjson conc "$(concurrency_json)" \
    --slurpfile metrics "$metrics" \
    --rawfile output "$out.clean" \
    --argjson turns "${turns:-0}" \
    --argjson exit "$rc" \
    '$meta + {turns:$turns, exit:$exit,
              metrics: ($metrics[0] // null),
              concurrency: $conc,
              output: $output}'
  rm -f "$metrics" "$out" "$out.clean"
  return "$rc"
}

# ---- subcommand: run-task --------------------------------------------------
cmd_run_task() {
  [ "${#POSITIONAL[@]}" -gt 0 ] || rxb_die "run-task: TASK.json is required"
  local task_file="${POSITIONAL[0]}"
  [ -f "$task_file" ] || rxb_die "run-task: file not found: $task_file"
  jq -e 'type == "object"' "$task_file" >/dev/null || rxb_die "run-task: TASK.json must be a JSON object"

  local file_type file_thread file_repo file_model file_agent file_steps prompt
  file_type=$(jq -r '.type // empty' "$task_file")
  file_thread=$(jq -r '.thread // empty' "$task_file")
  file_repo=$(jq -r '.repo // empty' "$task_file")
  file_model=$(jq -r '.model // empty' "$task_file")
  file_agent=$(jq -r '.agent // empty' "$task_file")
  file_steps=$(jq -r '.max_steps // empty' "$task_file")

  TYPE="${TYPE:-$file_type}"
  THREAD="${THREAD:-$file_thread}"
  [ "$REPO" = "$PWD" ] && [ -n "$file_repo" ] && REPO="$file_repo"
  RXB_MODEL_OVERRIDE="${RXB_MODEL_OVERRIDE:-$file_model}"
  AGENT="${AGENT:-$file_agent}"
  MAXSTEPS="${MAXSTEPS:-$file_steps}"

  [ -n "$TYPE" ] || rxb_die "run-task: missing required field: type"
  [ -n "$THREAD" ] || rxb_die "run-task: missing required field: thread"
  jq -e 'has("prompt") or has("objective")' "$task_file" >/dev/null \
    || rxb_die "run-task: TASK.json must include prompt or objective"

  prompt=$(jq -r '
    "You are a Reasonix sub-agent invoked by rxbroker using the reasonix-handoff/v1 protocol.\n" +
    "Follow the task envelope exactly. Respect scope and constraints. Prefer minimal, focused changes.\n" +
    "Return your final answer as either valid JSON matching expected_output/result_schema when requested, or concise Markdown otherwise.\n\n" +
    "TASK_ENVELOPE:\n" + (. | tojson)
  ' "$task_file")

  POSITIONAL=("$prompt")
  cmd_run
}

# ---- subcommand: capabilities ---------------------------------------------
cmd_capabilities() {
  rxb_init_paths "$REPO"
  local cap codegen_model review_model openspec_model reasonix_ok
  cap=$(rxb_cfg_get limits concurrency_cap || echo 4)
  codegen_model=$(rxb_cfg_get models codegen || echo "")
  review_model=$(rxb_cfg_get models review || echo "")
  openspec_model=$(rxb_cfg_get models openspec || echo "")
  if command -v reasonix >/dev/null 2>&1; then reasonix_ok=true; else reasonix_ok=false; fi
  jq -nc \
    --arg repo "$RXB_REPO_ID" \
    --argjson reasonix_available "$reasonix_ok" \
    --argjson cap "$cap" \
    --arg codegen_model "$codegen_model" \
    --arg review_model "$review_model" \
    --arg openspec_model "$openspec_model" \
    '{
      protocol:"reasonix-handoff/v1",
      repo:$repo,
      commands:["key","ensure","run","run-task","list","capabilities","promote","stop"],
      types:["codegen","review","openspec"],
      models:{codegen:$codegen_model, review:$review_model, openspec:$openspec_model},
      roles:{
        planner:{type:"openspec", writes:false, description:"Plan or draft OpenSpec artifacts."},
        implementer:{type:"codegen", writes:true, description:"Modify code for a scoped artifact."},
        reviewer:{type:"review", writes:false, description:"Critique code, diffs, specs, or plans."},
        tester:{type:"review", writes:false, description:"Run or design verification without editing by default."},
        fixer:{type:"codegen", writes:true, description:"Apply focused fixes after review or test failure."}
      },
      task_envelope:{required:["type","thread"], one_of:["prompt","objective"], optional:["repo","model","agent","max_steps","scope","constraints","expected_output","result_schema"]},
      result_contract:{status:["completed","blocked","failed"], fields:["summary","files_changed","tests_run","issues","next_steps"]},
      limits:{concurrency_cap:$cap},
      reasonix_available:$reasonix_available
    }'
}

# ---- subcommand: list ------------------------------------------------------
cmd_list() {
  rxb_init_paths "$REPO"
  rxb_index_init
  jq --arg type "$TYPE" --arg thread "$THREAD" '
    to_entries
    | map(.value + {key: .key})
    | map(select($type   == "" or .type   == $type))
    | map(select($thread == "" or .thread == $thread))
  ' "$RXB_INDEX"
}

# ---- subcommand: promote (opt-in serve) ------------------------------------
cmd_promote() {
  rxb_need_reasonix
  resolve_session
  [ -f "$SPATH_JSONL" ] || rxb_die "promote: no session for that key; run `ensure`/`run` first"
  local addr="${ADDR:-127.0.0.1:8787}"
  local logf="$RXB_STATE/serve-$KEY.log"
  nohup reasonix serve -model "$MODEL" -resume "$SPATH_JSONL" -addr "$addr" \
    >"$logf" 2>&1 &
  local pid=$!
  sleep 1
  if ! kill -0 "$pid" 2>/dev/null; then
    rxb_die "promote: serve failed to start (see $logf)"
  fi
  rxb_index_apply "$KEY" \
    ".[\$k].serve = {addr:\"$addr\", pid:$pid, log:\"$logf\"}"
  session_meta_json reused \
    | jq --arg addr "$addr" --argjson pid "$pid" --arg log "$logf" \
        '. + {serve:{addr:$addr, pid:$pid, log:$log, url:("http://"+$addr+"/")}}'
}

# ---- subcommand: stop ------------------------------------------------------
cmd_stop() {
  resolve_session
  local entry pid
  entry=$(rxb_index_get "$KEY" || true)
  pid=$(printf '%s' "$entry" | jq -r '.serve.pid // empty')
  if [ -n "$pid" ]; then kill "$pid" 2>/dev/null || true; fi
  rxb_index_apply "$KEY" "if .[\$k] then .[\$k] |= del(.serve) else . end"
  session_meta_json reused | jq '. + {stopped:true}'
}

# ---- dispatch --------------------------------------------------------------
[ $# -ge 1 ] || { usage; exit 1; }
SUB="$1"; shift
parse_args "$@"
case "$SUB" in
  key)          cmd_key ;;
  ensure)       cmd_ensure ;;
  run)          cmd_run ;;
  run-task)     cmd_run_task ;;
  list)         cmd_list ;;
  capabilities) cmd_capabilities ;;
  promote)      cmd_promote ;;
  stop)         cmd_stop ;;
  help|-h|--help) usage ;;
  *) rxb_die "unknown subcommand '$SUB' (see `rxbroker help`)" ;;
esac
